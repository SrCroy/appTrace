<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_top_bar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="@dimen/screen_padding"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_profile_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/dm_sans"
            android:text="@string/profile_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_edit_profile_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/editar_perfil"
            app:tint="@color/text_secondary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_top_bar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/screen_padding">

            <FrameLayout
                android:id="@+id/fl_avatar_profile"
                android:layout_width="@dimen/avatar_xl"
                android:layout_height="@dimen/avatar_xl"
                android:layout_marginTop="@dimen/space_md"
                android:background="@drawable/bg_avatar"
                android:backgroundTint="@color/purple"
                android:outlineProvider="background"
                android:clipToOutline="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <TextView
                    android:id="@+id/tv_avatar_initials"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/dm_sans"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_2xl"
                    android:textStyle="bold"
                    tools:text="CM" />
                <ImageView
                    android:id="@+id/iv_avatar_profile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />
            </FrameLayout>

            <ImageView
                android:id="@+id/iv_verified_badge"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/verificado"
                android:translationX="4dp"
                android:translationY="4dp"
                app:layout_constraintBottom_toBottomOf="@id/fl_avatar_profile"
                app:layout_constraintEnd_toEndOf="@id/fl_avatar_profile"
                app:tint="@color/success" />

            <TextView
                android:id="@+id/tv_full_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:fontFamily="@font/dm_sans"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_2xl"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/fl_avatar_profile"
                app:layout_constraintTop_toTopOf="@id/fl_avatar_profile"
                tools:text="Carlos Méndez" />

            <TextView
                android:id="@+id/tv_username"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:fontFamily="@font/dm_sans"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_md"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/fl_avatar_profile"
                app:layout_constraintTop_toBottomOf="@id/tv_full_name"
                tools:text="\@cmenddez" />

            <TextView
                android:id="@+id/tv_location"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_xs"
                android:fontFamily="@font/dm_sans"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm"
                app:drawableTint="@color/text_secondary"
                android:drawablePadding="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/fl_avatar_profile"
                app:layout_constraintTop_toBottomOf="@id/tv_username"
                tools:text="San Salvador, SV" />

            <TextView
                android:id="@+id/tv_bio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:fontFamily="@font/dm_sans"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md"
                android:lineSpacingExtra="4dp"
                app:layout_constraintTop_toBottomOf="@id/tv_location"
                tools:text="Corredor apasionado. Madrugador empedernido. Trail runner los fines de semana." />

            <LinearLayout
                android:id="@+id/ll_action_buttons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tv_bio">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_edit_profile"
                    style="@style/Widget.Trace.Button"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/btn_height"
                    android:layout_weight="2"
                    android:layout_marginEnd="@dimen/space_md"
                    android:text="@string/btn_edit_profile"
                    android:textSize="@dimen/text_base" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_friends"
                    style="@style/Widget.Trace.Button"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/btn_height"
                    android:layout_weight="1"
                    android:backgroundTint="@color/surface_2"
                    android:textColor="@color/text_primary"
                    android:text="@string/label_friends"
                    android:textSize="@dimen/text_base" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_global_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:orientation="horizontal"
                android:weightSum="3"
                app:layout_constraintTop_toBottomOf="@id/ll_action_buttons">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Trace.CardView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="@dimen/space_lg">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_2xl"
                            android:textStyle="bold"
                            tools:text="127" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/text_disabled"
                            android:textSize="@dimen/text_xs"
                            android:text="Actividades" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Trace.CardView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="@dimen/space_lg">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_2xl"
                            android:textStyle="bold"
                            tools:text="842" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/text_disabled"
                            android:textSize="@dimen/text_xs"
                            android:text="Kilómetros" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Trace.CardView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="@dimen/space_lg">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_2xl"
                            android:textStyle="bold"
                            tools:text="64" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/text_disabled"
                            android:textSize="@dimen/text_xs"
                            android:text="Amigos" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_heatmap_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:fontFamily="@font/dm_sans"
                android:text="Actividad 2024"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ll_global_stats" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/dm_sans"
                android:text="127 registros"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/tv_heatmap_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_heatmap_title" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cv_heatmap"
                style="@style/Widget.Trace.CardView"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="@dimen/space_md"
                app:layout_constraintTop_toBottomOf="@id/tv_heatmap_title">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/surface_2"
                    android:contentDescription="Mapa de calor de actividad" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tv_recent_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:fontFamily="@font/dm_sans"
                android:text="ACTIVIDADES RECIENTES"
                android:textColor="@color/text_disabled"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cv_heatmap" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recent_activities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:nestedScrollingEnabled="false"
                app:layout_constraintTop_toBottomOf="@id/tv_recent_title"
                tools:listitem="@layout/item_actividad_historial"
                tools:itemCount="3" />

            <TextView
                android:id="@+id/tv_logros_profile_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:fontFamily="@font/dm_sans"
                android:text="LOGROS"
                android:textColor="@color/text_disabled"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rv_recent_activities" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cv_logros_preview"
                style="@style/Widget.Trace.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintTop_toBottomOf="@id/tv_logros_profile_title">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_md">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_avatar"
                        android:backgroundTint="@color/warning">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_launcher_foreground"
                            app:tint="@color/background" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_md"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_logros_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dm_sans"
                            android:text="Cargando logros..."
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_base"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_logros_pct"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dm_sans"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_sm"
                            android:visibility="gone" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_launcher_foreground"
                        app:tint="@color/text_disabled" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                style="@style/Widget.Trace.Button"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/space_2xl"
                android:layout_marginBottom="24dp"
                android:backgroundTint="@color/surface_2"
                android:text="Cerrar sesión"
                android:textColor="@color/error"
                android:textSize="@dimen/text_base"
                app:layout_constraintTop_toBottomOf="@id/cv_logros_preview"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>