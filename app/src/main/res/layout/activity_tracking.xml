<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ImageView
        android:id="@+id/iv_map_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/surface_2"
        android:scaleType="centerCrop"
        android:alpha="0.5"
        android:contentDescription="Mapa en vivo" />

    <LinearLayout
        android:id="@+id/ll_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/screen_padding"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_launcher_foreground"
            app:tint="@color/text_primary" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_avatar"
            android:backgroundTint="@color/overlay_dark"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_avatar"
                android:backgroundTint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/dm_sans"
                android:text="@string/tracking_status_running"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <View
            android:layout_width="28dp"
            android:layout_height="28dp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.Trace.CardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@color/surface_1"
        android:layout_margin="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/space_xl">

            <View
                android:id="@+id/v_drag_handle"
                android:layout_width="@dimen/drag_handle_width"
                android:layout_height="@dimen/drag_handle_height"
                android:background="@drawable/bg_avatar"
                android:backgroundTint="@color/border"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tv_main_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:fontFamily="@font/dm_sans"
                android:text="42:18"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_stat_lg"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/v_drag_handle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tv_timer_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/dm_sans"
                android:text="TIEMPO TRANSCURRIDO"
                android:textColor="@color/text_disabled"
                android:textSize="@dimen/text_xs"
                app:layout_constraintTop_toBottomOf="@id/tv_main_timer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <GridLayout
                android:id="@+id/gl_metrics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:columnCount="3"
                android:rowCount="2"
                android:useDefaultMargins="true"
                app:layout_constraintTop_toBottomOf="@id/tv_timer_label">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_avatar"
                    android:backgroundTint="@color/surface_2"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_launcher_foreground"
                        app:tint="@color/primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="8.4"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_xl"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DISTANCIA km"
                        android:textColor="@color/text_disabled"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_avatar"
                    android:backgroundTint="@color/surface_2"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_launcher_foreground"
                        app:tint="@color/accent" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="5:02"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_xl"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RITMO /km"
                        android:textColor="@color/text_disabled"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_avatar"
                    android:backgroundTint="@color/surface_2"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_launcher_foreground"
                        app:tint="@color/error" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="152"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_xl"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CARDIACA bpm"
                        android:textColor="@color/text_disabled"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_avatar"
                    android:backgroundTint="@color/surface_2"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+125"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_xl"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DESNIVEL m"
                        android:textColor="@color/text_disabled"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_avatar"
                    android:backgroundTint="@color/surface_2"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="428"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_xl"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CALORÍAS kcal"
                        android:textColor="@color/text_disabled"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/bg_avatar"
                    android:backgroundTint="@color/surface_2"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8,240"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_xl"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PASOS"
                        android:textColor="@color/text_disabled"
                        android:textSize="10sp" />
                </LinearLayout>

            </GridLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/gl_metrics">

                <com.google.android.material.button.MaterialButton
                    id="@+id/btn_pause"
                    style="@style/Widget.Trace.Button"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_md"
                    android:backgroundTint="@color/surface_2"
                    android:textColor="@color/text_primary"
                    android:text="@string/btn_pause"
                    android:textSize="@dimen/text_lg"
                    app:icon="@drawable/ic_launcher_foreground"
                    app:iconTint="@color/text_primary"
                    app:iconGravity="textStart"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    id="@+id/btn_stop"
                    style="@style/Widget.Trace.Button"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:backgroundTint="@color/surface_3"
                    app:strokeColor="@color/error"
                    app:strokeWidth="1dp"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_launcher_foreground"
                    app:iconTint="@color/error"
                    app:iconSize="24dp"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>