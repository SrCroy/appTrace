<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    tools:context=".DetalleRutaActivity">

    <FrameLayout
        android:id="@+id/fl_map_detalle"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="@color/surface_2"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/ll_top_bar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/screen_padding"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/fl_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_avatar"
            android:backgroundTint="@color/overlay_dark">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/x"
                app:tint="@color/text_primary" />
        </FrameLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <FrameLayout
            android:id="@+id/fl_edit_route"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_avatar"
            android:backgroundTint="@color/overlay_dark">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/lapiz"
                app:tint="@color/text_primary" />
        </FrameLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cl_bottom_action">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="220dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/background"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/screen_padding">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_route_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/dm_sans"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_2xl"
                            android:textStyle="bold"
                            tools:text="Ruta del Boquerón" />

                        <TextView
                            android:id="@+id/tv_difficulty"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_sm"
                            android:background="@drawable/bg_avatar"
                            android:backgroundTint="#1AFF9A3C"
                            android:fontFamily="@font/dm_sans"
                            android:paddingHorizontal="@dimen/tag_padding_h"
                            android:paddingVertical="@dimen/tag_padding_v"
                            android:textColor="@color/diff_medium"
                            android:textSize="@dimen/text_xs"
                            android:textStyle="bold"
                            tools:text="Moderado" />
                    </LinearLayout>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_sport"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_avatar"
                            android:backgroundTint="@color/type_trail_bg"
                            android:fontFamily="@font/dm_sans"
                            android:paddingHorizontal="@dimen/tag_padding_h"
                            android:paddingVertical="@dimen/tag_padding_v"
                            android:textColor="@color/type_trail"
                            android:textSize="@dimen/text_xs"
                            android:textStyle="bold"
                            tools:text="Trail" />

                        <TextView
                            android:id="@+id/tv_location"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_md"
                            android:fontFamily="@font/dm_sans"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_sm"
                            app:drawableTint="@color/text_secondary"
                            android:drawablePadding="4dp"
                            tools:text="San Salvador, SV" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xl"
                        android:baselineAligned="false"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_stat_distance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/dm_sans"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_xl"
                                android:textStyle="bold"
                                tools:text="12.4 km" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/dm_sans"
                                android:text="DISTANCIA"
                                android:textColor="@color/text_disabled"
                                android:textSize="@dimen/text_xs" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_stat_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/dm_sans"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_xl"
                                android:textStyle="bold"
                                tools:text="2h 05m" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/dm_sans"
                                android:text="TIEMPO EST."
                                android:textColor="@color/text_disabled"
                                android:textSize="@dimen/text_xs" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_stat_elevation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/dm_sans"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_xl"
                                android:textStyle="bold"
                                tools:text="+520m" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/dm_sans"
                                android:text="DESNIVEL"
                                android:textColor="@color/text_disabled"
                                android:textSize="@dimen/text_xs" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/space_xl"
                        android:background="@color/divider" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/dm_sans"
                        android:text="Descripción"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:fontFamily="@font/dm_sans"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm"
                        android:lineSpacingExtra="4dp"
                        tools:text="Ruta de trail hacia el cráter del Boquerón. Sendero bien marcado con vistas espectaculares del Valle de San Salvador. Recomendado zapatos de trail. Llevar suficiente agua." />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/space_xl"
                        android:background="@color/divider" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/dm_sans"
                        android:text="Creada por"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="@dimen/avatar_sm"
                            android:layout_height="@dimen/avatar_sm"
                            android:background="@drawable/bg_avatar"
                            android:backgroundTint="@color/accent_dark">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:fontFamily="@font/dm_sans"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold"
                                android:text="RS" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_creator_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_md"
                            android:fontFamily="@font/dm_sans"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            tools:text="Roberto Silva" />
                    </LinearLayout>


                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_bottom_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_1"
        android:padding="@dimen/screen_padding"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_route"
            style="@style/Widget.Trace.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height"
            android:text="@string/btn_start_route"
            android:textSize="@dimen/text_base"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>