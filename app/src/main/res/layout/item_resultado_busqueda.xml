<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingVertical="@dimen/space_sm">

    <FrameLayout
        android:id="@+id/fl_result_image"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_avatar"
        android:backgroundTint="@color/surface_2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_result_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_launcher_foreground"
            app:tint="@color/text_secondary" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_md"
        android:layout_marginEnd="@dimen/space_sm"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_result_action"
        app:layout_constraintStart_toEndOf="@id/fl_result_image"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_result_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/dm_sans"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_base"
            android:textStyle="bold"
            tools:text="Carlos Méndez" />

        <TextView
            android:id="@+id/tv_result_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/dm_sans"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm"
            tools:text="Corredor • San Salvador" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_result_action"
        style="@style/Widget.Trace.Button.Outline"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:paddingHorizontal="12dp"
        android:textSize="@dimen/text_xs"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="@color/border" />

</androidx.constraintlayout.widget.ConstraintLayout>