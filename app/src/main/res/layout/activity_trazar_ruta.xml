<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Mapa ocupa toda la pantalla -->
    <fragment
        android:id="@+id/map_trazar"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Barra superior flotante -->
    <LinearLayout
        android:id="@+id/ll_trazar_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#CC000000"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/fl_trazar_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_avatar"
            android:backgroundTint="@color/surface_2">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_launcher_foreground"
                app:tint="@color/text_primary" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/dm_sans"
            android:text="Toca el mapa para agregar puntos"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_point_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/dm_sans"
            android:text="0 puntos"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Barra de búsqueda flotante -->
    <LinearLayout
        android:id="@+id/ll_trazar_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/ll_trazar_top">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#EE1a1a2e"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <EditText
                android:id="@+id/et_trazar_buscar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="14dp"
                android:background="@null"
                android:hint="Buscar calle o lugar..."
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_disabled"
                android:textSize="14sp"
                android:fontFamily="@font/dm_sans"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_trazar_buscar"
            style="@style/Widget.Trace.Button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:padding="0dp"
            android:text="→"
            android:textSize="18sp"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <!-- Panel inferior flotante -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_trazar_bottom"
        style="@style/Widget.Trace.CardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Distancia total -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/dm_sans"
                    android:text="DISTANCIA TOTAL"
                    android:textColor="@color/text_disabled"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_trazar_distancia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/dm_sans"
                    android:text="0.00 km"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Botones -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_trazar_deshacer"
                    style="@style/Widget.Trace.Button"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="@color/surface_2"
                    android:textColor="@color/text_primary"
                    android:text="Deshacer"
                    android:textSize="14sp"
                    app:cornerRadius="14dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_trazar_limpiar"
                    style="@style/Widget.Trace.Button"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="@color/surface_3"
                    app:strokeColor="@color/error"
                    app:strokeWidth="1dp"
                    android:textColor="@color/error"
                    android:text="Limpiar"
                    android:textSize="14sp"
                    app:cornerRadius="14dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_trazar_listo"
                    style="@style/Widget.Trace.Button"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Listo"
                    android:textSize="14sp"
                    app:cornerRadius="14dp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
