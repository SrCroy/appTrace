<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/ll_top_bar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/screen_padding"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#00000000">
        <FrameLayout
            android:id="@+id/fl_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_avatar"
            android:backgroundTint="@color/overlay_dark">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/flecha_pequena_izquierda"
                app:tint="@color/text_primary" />
        </FrameLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <FrameLayout
            android:id="@+id/fl_share_group"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_avatar"
            android:backgroundTint="@color/overlay_dark">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/compartir"
                app:tint="@color/text_primary" />
        </FrameLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/space_2xl">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/iv_group_cover"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:background="@color/surface_2"
                android:scaleType="centerCrop"
                app:layout_constraintTop_toTopOf="parent" />

            <FrameLayout
                android:id="@+id/fl_group_avatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginStart="@dimen/screen_padding"
                android:background="@drawable/bg_avatar"
                android:backgroundTint="@color/surface_1"
                android:elevation="2dp"
                app:layout_constraintBottom_toBottomOf="@id/iv_group_cover"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_group_cover">

                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_avatar"
                    android:backgroundTint="@color/type_run_bg">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:src="@drawable/camara"
                        app:tint="@color/type_run" />
                </FrameLayout>
            </FrameLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                app:layout_constraintTop_toBottomOf="@id/iv_group_cover">

                <TextView
                    android:id="@+id/tv_group_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp"
                    android:fontFamily="@font/dm_sans"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_2xl"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="Corredores del Valle" />

                <TextView
                    android:id="@+id/tv_group_sport"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:background="@drawable/bg_avatar"
                    android:backgroundTint="@color/type_run_bg"
                    android:fontFamily="@font/dm_sans"
                    android:paddingHorizontal="@dimen/tag_padding_h"
                    android:paddingVertical="@dimen/tag_padding_v"
                    android:textColor="@color/type_run"
                    android:textSize="@dimen/text_xs"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_group_name"
                    tools:text="Carrera" />

                <TextView
                    android:id="@+id/tv_group_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:fontFamily="@font/dm_sans"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm"
                    android:lineSpacingExtra="4dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_group_sport"
                    tools:text="Comunidad dedicada a los apasionados del running en el valle. Organizamos salidas grupales todos los fines de semana y compartimos rutas seguras." />

                <LinearLayout
                    android:id="@+id/ll_group_stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    app:layout_constraintTop_toBottomOf="@id/tv_group_description">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/grupo"
                        app:tint="@color/text_disabled" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="@font/dm_sans"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_sm"
                        android:textStyle="bold"
                        tools:text="128" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="@font/dm_sans"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm"
                        text="miembros" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="@dimen/space_lg"
                        android:src="@drawable/ruta"
                        app:tint="@color/text_disabled" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="@font/dm_sans"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_sm"
                        android:textStyle="bold"
                        tools:text="340" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="@font/dm_sans"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm"
                        text="actividades" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_join_group"
                    style="@style/Widget.Trace.Button"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/btn_height"
                    android:layout_marginTop="@dimen/space_lg"
                    android:text="@string/btn_join"
                    android:textSize="@dimen/text_base"
                    app:iconGravity="textStart"
                    app:layout_constraintTop_toBottomOf="@id/ll_group_stats" />

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tl_group_tabs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xl"
                    android:background="@color/background"
                    app:tabIndicatorColor="@color/primary"
                    app:tabSelectedTextColor="@color/primary"
                    app:tabTextColor="@color/text_secondary"
                    app:tabMode="scrollable"
                    app:tabTextAppearance="@style/TextAppearance.AppCompat.Small"
                    app:layout_constraintTop_toBottomOf="@id/btn_join_group">

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Feed" />
                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Retos" />
                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Miembros" />
                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Logros" />
                </com.google.android.material.tabs.TabLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_group_feed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:nestedScrollingEnabled="false"
                    app:layout_constraintTop_toBottomOf="@id/tl_group_tabs"
                    tools:listitem="@layout/item_publicacion"
                    tools:itemCount="3" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>