<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:fitsSystemWindows="true"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ================= CABECERA ================= -->
    <LinearLayout
        android:id="@+id/ll_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/screen_padding"
        android:paddingTop="@dimen/space_xl"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_routes_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/dm_sans"
            android:text="@string/routes_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_3xl"
            android:textStyle="bold" />

        <!-- Espaciador -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Ícono de Filtro -->
        <ImageView
            android:id="@+id/iv_filter_routes"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="@dimen/space_md"
            android:src="@drawable/ic_launcher_foreground"
            app:tint="@color/text_secondary" />

        <!-- Botón Agregar (+) -->
        <FrameLayout
            android:id="@+id/fl_add_route"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_avatar"
            android:backgroundTint="@color/primary">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_launcher_foreground"
                app:tint="@color/background" />
        </FrameLayout>
    </LinearLayout>

    <!-- ================= BARRA DE BÚSQUEDA ================= -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_search_routes"
        style="@style/Widget.Trace.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/screen_padding"
        android:layout_marginTop="@dimen/space_lg"
        android:hint="Buscar rutas cerca de ti..."
        app:startIconTint="@color/text_secondary"
        app:layout_constraintTop_toBottomOf="@id/ll_header">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_search_routes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:imeOptions="actionSearch" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- ================= FILTROS HORIZONTALES ================= -->
    <HorizontalScrollView
        android:id="@+id/hsv_filters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/screen_padding"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/til_search_routes">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Filtro Activo: Todos -->
            <TextView
                android:id="@+id/chip_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_sm"
                android:background="@drawable/bg_avatar"
                android:backgroundTint="@color/type_run_bg"
                android:fontFamily="@font/dm_sans"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="@string/tab_all"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold" />

            <!-- Filtros Inactivos -->
            <TextView
                android:id="@+id/chip_trail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_sm"
                android:background="@drawable/bg_avatar"
                android:backgroundTint="@color/surface_2"
                android:fontFamily="@font/dm_sans"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="@string/type_trail"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm" />

            <TextView
                android:id="@+id/chip_run"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_sm"
                android:background="@drawable/bg_avatar"
                android:backgroundTint="@color/surface_2"
                android:fontFamily="@font/dm_sans"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="@string/type_run"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm" />

            <TextView
                android:id="@+id/chip_cycle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_sm"
                android:background="@drawable/bg_avatar"
                android:backgroundTint="@color/surface_2"
                android:fontFamily="@font/dm_sans"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="@string/type_cycle"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm" />

            <TextView
                android:id="@+id/chip_swim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_avatar"
                android:backgroundTint="@color/surface_2"
                android:fontFamily="@font/dm_sans"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="@string/type_swim"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ================= LISTA DE RUTAS ================= -->
    <!-- Usaremos un placeholder temporal hasta crear item_ruta -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_routes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_md"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/screen_padding"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hsv_filters"
        tools:listitem="@layout/item_ruta" />

    <!-- ================= BARRA DE NAVEGACIÓN INFERIOR ================= -->
    <View
        android:id="@+id/v_bottom_nav_bg"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:background="@color/surface_1"
        app:layout_constraintBottom_toBottomOf="parent" />

    <LinearLayout
        android:id="@+id/ll_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Inicio -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_launcher_foreground"
                app:tint="@color/text_secondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/dm_sans"
                android:text="@string/nav_feed"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_xs" />
        </LinearLayout>

        <!-- PESTAÑA ACTIVA: Rutas -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_launcher_foreground"
                app:tint="@color/primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/dm_sans"
                android:text="@string/nav_routes"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_xs" />
        </LinearLayout>

        <!-- Espacio central FAB principal -->
        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <!-- Grupos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_launcher_foreground"
                app:tint="@color/text_secondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/dm_sans"
                android:text="@string/nav_groups"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_xs" />
        </LinearLayout>

        <!-- Perfil -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_launcher_foreground"
                app:tint="@color/text_secondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/dm_sans"
                android:text="@string/nav_profile"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_xs" />
        </LinearLayout>
    </LinearLayout>

    <!-- BOTÓN CENTRAL FLOTANTE (Para el tracking global) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_track_activity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/primary_light"
        android:src="@drawable/ic_launcher_foreground"
        app:borderWidth="0dp"
        app:elevation="4dp"
        app:fabCustomSize="64dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:maxImageSize="32dp"
        app:tint="@color/background" />

</androidx.constraintlayout.widget.ConstraintLayout>