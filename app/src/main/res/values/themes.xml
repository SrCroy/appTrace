<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base Trace Theme — Material3 Dark -->
    <style name="Theme.Trace" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/background</item>
        <item name="colorPrimaryContainer">@color/surface_2</item>
        <item name="colorOnPrimaryContainer">@color/primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/background</item>
        <item name="colorSecondaryContainer">@color/surface_2</item>
        <item name="colorOnSecondaryContainer">@color/accent</item>
        <item name="colorSurface">@color/surface_1</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_2</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="backgroundColor">@color/background</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">@color/error</item>
        <item name="colorOutline">@color/border</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="bottomNavigationStyle">@style/Widget.Trace.BottomNavigationView</item>
        <item name="materialCardViewStyle">@style/Widget.Trace.CardView</item>
        <item name="materialButtonStyle">@style/Widget.Trace.Button</item>
        <item name="textInputStyle">@style/Widget.Trace.TextInputLayout</item>
    </style>

    <style name="Theme.Trace.Splash" parent="Theme.Trace">
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Shape Appearances -->
    <style name="ShapeAppearance.Trace.ExtraLarge" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
    <style name="ShapeAppearance.Trace.Large" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    <style name="ShapeAppearance.Trace.Medium" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeAppearance.Trace.Small" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="Widget.Trace" parent="android:Widget" />

    <!-- Bottom Navigation -->
    <style name="Widget.Trace.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/background</item>
        <item name="itemIconTint">@color/selector_bottom_nav</item>
        <item name="itemTextColor">@color/selector_bottom_nav</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <!-- Card -->
    <style name="Widget.Trace.CardView" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface_1</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- Primary Button -->
    <style name="Widget.Trace.Button" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/background</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
    </style>

    <!-- Outline Button -->
    <style name="Widget.Trace.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">24dp</item>
    </style>

    <!-- Text Input -->
    <style name="Widget.Trace.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface_3</item>
        <item name="boxStrokeColor">@color/border</item>
        <item name="android:textColorHint">@color/text_disabled</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Bottom Sheet -->
    <style name="Widget.Trace.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">@color/surface_1</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Trace.ExtraLarge</item>
    </style>
</resources>