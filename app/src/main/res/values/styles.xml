<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Text Styles -->
    <style name="TextAppearance.Trace.Display" parent="TextAppearance.Material3.DisplayMedium">
        <item name="android:fontFamily">@font/dm_sans_bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.Trace.Heading" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/dm_sans_semibold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Trace.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">@font/dm_sans_semibold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Trace.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Trace.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.Trace.Mono" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Trace.Stat" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/jetbrains_mono_semibold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Divider -->
    <style name="Widget.Trace.Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/divider</item>
    </style>

    <!-- Chip / Tag -->
    <style name="Widget.Trace.Tag" parent="Widget.Material3.Chip.Assist">
        <item name="android:textSize">@dimen/text_xs</item>
        <item name="chipCornerRadius">@dimen/tag_radius</item>
        <item name="chipStartPadding">@dimen/tag_padding_h</item>
        <item name="chipEndPadding">@dimen/tag_padding_h</item>
        <item name="chipMinHeight">22dp</item>
    </style>

    <!-- Icon Button -->
    <style name="Widget.Trace.IconButton" parent="Widget.Material3.Button.IconButton">
        <item name="android:backgroundTint">@color/surface_2</item>
        <item name="iconTint">@color/text_secondary</item>
    </style>

    <!-- Avatar -->
    <style name="Widget.Trace.Avatar">
        <item name="android:scaleType">centerCrop</item>
        <item name="android:background">@drawable/bg_avatar</item>
    </style>
</resources>